## Contact form (SMTP)
#
# Copy to .env.local and fill in values to enable /api/contact email sending.
# If not configured, the API will return "Not configured" and the UI will tell
# the visitor to call instead.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where contact emails should be delivered
CONTACT_TO_EMAIL=

# Sender address (some SMTP providers require this to match SMTP_USER)
CONTACT_FROM_EMAIL=

